# Copy this file to .env and fill in the values for your chosen provider.
# Only one provider is active at a time. Set VITE_MARKET_PROVIDER to one of:
#   polygon | alpaca | tradovate | binance | yahoo
# If VITE_MARKET_PROVIDER is not set, the app uses built-in sample data.

VITE_MARKET_PROVIDER=

# ── Polygon.io ──────────────────────────────────────────────────────────────
# https://polygon.io/dashboard/api-keys
VITE_POLYGON_API_KEY=

# ── Alpaca ──────────────────────────────────────────────────────────────────
# https://app.alpaca.markets/paper/dashboard/overview
VITE_ALPACA_API_KEY=
VITE_ALPACA_API_SECRET=

# ── Tradovate ────────────────────────────────────────────────────────────────
# https://apidev.tradovate.com/
VITE_TRADOVATE_USERNAME=
VITE_TRADOVATE_PASSWORD=
VITE_TRADOVATE_APP_ID=
VITE_TRADOVATE_APP_VERSION=1.0
VITE_TRADOVATE_CID=
VITE_TRADOVATE_SEC=
# VITE_TRADOVATE_ENV=demo   # 'live' or 'demo'

# ── Binance ──────────────────────────────────────────────────────────────────
# Public OHLCV endpoints work without a key.
# VITE_BINANCE_API_KEY=     # optional — only needed for private endpoints

# ── Yahoo Finance ────────────────────────────────────────────────────────────
# No key required. Set a CORS proxy if needed in browser environments.
# VITE_YAHOO_CORS_PROXY=https://corsproxy.io/?
